# ===========================================
# AI Commit Reporter - Configurações (.env)
# ===========================================

# --- Git Provider (GitHub) ---
# Token e repositório do GitHub
GITHUB_TOKEN=seu_token_aqui
GITHUB_USER=seu_usuario_ou_org
GITHUB_REPO=nome_do_repositorio
GITHUB_URL=https://api.github.com

# --- Groq API (IA na Nuvem) ---
GROQ_API_KEY=seu_groq_api_key_aqui
MODEL_NAME=llama-3.3-70b-versatile

# --- Notificações (Telegram) ---
# Para configurar:
# 1. Crie um bot no @BotFather no Telegram
# 2. Inicie uma conversa com o bot
# 3. Pegue o chat_id em https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui
NOTIFY_ENABLED=true

# --- Configurações de Segurança e Servidor ---
WEBHOOK_SECRET=sua_chave_secreta_webhook
HOSTNAME=seu_hostname
DASHBOARD_URL=http://localhost:8000

# --- Configurações de Processamento ---
MAX_DIFF_LENGTH=4000
TIMEZONE_OFFSET=-4  # -4 para Manaus, -3 para Brasília
