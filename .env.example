# ===========================================
# AI Commit Reporter - Configurações (.env)
# ===========================================

# --- Git Provider (Gitea ou GitHub) ---
# Gitea (padrão)
GITEA_TOKEN=seu_token_aqui
GITEA_USER=seu_usuario_ou_org
GITEA_REPO=nome_do_repositorio
GITEA_URL=https://gitea.com

# GitHub (alternativa)
GITHUB_TOKEN=seu_token_aqui
GITHUB_USER=seu_usuario
GITHUB_REPO=nome_do_repositorio

# --- Groq API (IA na Nuvem) ---
GROQ_API_KEY=seu_groq_api_key_aqui
# Modelo opcional (padrão: llama-3.3-70b-versatile)
MODEL_NAME=llama-3.3-70b-versatile

# --- Configurações de Processamento ---
# Limite de caracteres do diff (padrão: 4000)
MAX_DIFF_LENGTH=4000

# Fuso horário em horas (padrão: -4 para Manaus, -3 para Brasília)
TIMEZONE_OFFSET=-4

# --- API Webhook ---
# Segredo para verificar assinatura dos webhooks (opcional, mas recomendado)
WEBHOOK_SECRET=seu_segredo_aqui

# --- Servidor API ---
# Hostname para exibição no dashboard (opcional)
HOSTNAME=meu-servidor

# Porta do servidor API (padrão: 8000)
API_PORT=8000
